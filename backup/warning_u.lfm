object WarningF: TWarningF
  Caption = 'Warning'
  Color = clBtnFace
  Position = poScreenCenter
  OnCloseQuery = FormCloseQuery
  object Label1: TLabel
    Left = 16
    Top = 16
    Width = 392
    Height = 20
    Caption = 'Warning! This operation may modify backup settings.'
    Font.Style = [fsBold]
  end
  object Label2: TLabel
    Left = 16
    Top = 40
    Width = 392
    Height = 16
    Caption = 'Please verify your selection before continuing.'
  end
  object Label3: TLabel
    Left = 16
    Top = 60
    Width = 392
    Height = 16
    Caption = 'Unsaved changes may be lost if you proceed.'
  end
  object Label4: TLabel
    Left = 16
    Top = 88
    Width = 392
    Height = 16
    Caption = 'Click OK to continue or Cancel to abort.'
  end
  object Label5: TLabel
    Left = 16
    Top = 112
    Width = 392
    Height = 16
    Caption = 'Make sure your backup device is connected.'
  end
  object BitBtn1: TBitBtn
    Left = 96
    Top = 136
    Width = 96
    Height = 32
    Caption = 'OK'
    ModalResult = mrOk
    OnClick = BitBtn1Click
  end
  object BitBtn2: TBitBtn
    Left = 224
    Top = 136
    Width = 96
    Height = 32
    Caption = 'Cancel'
    ModalResult = mrCancel
    OnClick = BitBtn2Click
  end
end
